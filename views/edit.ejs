<!DOCTYPE html>
<html>
<head>
   <title>Edit Record</title>
   <link rel="stylesheet" href="/css/style.css">
</head>
<body>
   <nav>
      <h2>OpsTrack</h2>
      <div>
         <a href="/dashboard">Dashboard</a>
         <a href="/logout">Logout</a>
      </div>
   </nav>

   <main>
      <div class="form-container">
         <h1>Edit Business Record</h1>

         <form action="/edit/<%= record.id %>" method="POST" onsubmit="return validateRecordForm()">
            <label>Category</label>
            <input type="text" id="category" name="category" value="<%= record.category %>">

            <label>Amount</label>
            <input type="number" id="amount" name="amount" step="0.01" value="<%= record.amount %>">

            <label>Date</label>
            <input 
               type="date" 
               id="record_date" 
               name="record_date" 
               value="<%= record.record_date.toISOString().split("T")[0] %>"
            >

            <label>Notes</label>
            <input type="text" id="notes" name="notes" value="<%= record.notes %>">

            <button type="submit">Update Record</button>
         </form>
      </div>
   </main>

   <script src="/js/validation.js"></script>
</body>
</html>
